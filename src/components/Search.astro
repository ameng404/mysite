---
import { Icon } from 'astro-icon/components'
import { url } from '@utils/url-utils'
import { i18n } from '@i18n/translation'
import I18nKey from '@i18n/i18nKey'
---
<!-- search bar for desktop view -->
<div id="search-bar" class="hidden lg:flex transition-all items-center h-11 mr-2 rounded-lg
      bg-black/[0.04] hover:bg-black/[0.06] focus-within:bg-black/[0.06]
      dark:bg-white/5 dark:hover:bg-white/10 dark:focus-within:bg-white/10
">
    <Icon name="material-symbols:search" class="absolute text-[1.25rem] pointer-events-none ml-3 transition my-auto text-black/30 dark:text-white/30" />
    <input placeholder={i18n(I18nKey.search)} id="search-input-desktop"
           class="transition-all pl-10 text-sm bg-transparent outline-0
         h-full w-40 active:w-60 focus:w-60 text-black/50 dark:text-white/50"
    >
</div>

<!-- toggle btn for phone/tablet view -->
<button aria-label="Search Panel" id="search-switch"
        class="btn-plain scale-animation lg:!hidden rounded-lg w-11 h-11 active:scale-90">
    <Icon name="material-symbols:search" class="text-[1.25rem]" />
</button>

<!-- search panel -->
<div id="search-panel" class="float-panel float-panel-closed search-panel absolute md:w-[30rem]
top-20 left-4 md:left-[unset] right-4 shadow-2xl rounded-2xl p-2">

    <!-- search bar inside panel for phone/tablet -->
    <div id="search-bar-inside" class="flex relative lg:hidden transition-all items-center h-11 rounded-xl
      bg-black/[0.04] hover:bg-black/[0.06] focus-within:bg-black/[0.06]
      dark:bg-white/5 dark:hover:bg-white/10 dark:focus-within:bg-white/10
  ">
        <Icon name="material-symbols:search" class="absolute text-[1.25rem] pointer-events-none ml-3 transition my-auto text-black/30 dark:text-white/30" />
        <input placeholder={i18n(I18nKey.search)} id="search-input-mobile"
               class="pl-10 absolute inset-0 text-sm bg-transparent outline-0
               focus:w-60 text-black/50 dark:text-white/50"
        >
    </div>

    <!-- pre-rendered icon template for search results -->
    <template id="search-result-icon">
        <Icon name="fa6-solid:chevron-right" class="transition text-[0.75rem] translate-x-1 my-auto text-[var(--primary)]" />
    </template>

    <!-- search results container -->
    <div id="search-results"></div>
</div>

<style>
    input:focus {
        outline: 0;
    }
</style>

<script>
import { url } from '@utils/url-utils'

const fakeResult = [
    {
        url: url('/'),
        meta: { title: 'This Is a Fake Search Result' },
        excerpt: 'Because the search cannot work in the <mark>dev</mark> environment.',
    },
    {
        url: url('/'),
        meta: { title: 'If You Want to Test the Search' },
        excerpt: 'Try running <mark>npm build && npm preview</mark> instead.',
    },
]

function initSearch() {
    const panel = document.getElementById('search-panel')
    const resultsContainer = document.getElementById('search-results')
    const desktopInput = document.getElementById('search-input-desktop') as HTMLInputElement
    const mobileInput = document.getElementById('search-input-mobile') as HTMLInputElement
    const switchBtn = document.getElementById('search-switch')
    const iconTemplate = document.getElementById('search-result-icon') as HTMLTemplateElement
    if (!panel || !resultsContainer || !desktopInput || !mobileInput || !switchBtn || !iconTemplate) return

    async function doSearch(keyword: string, isDesktop: boolean) {
        if (!keyword && isDesktop) {
            panel.classList.add('float-panel-closed')
            return
        }

        let arr: any[] = []
        if (import.meta.env.PROD) {
            const ret = await (window as any).pagefind.search(keyword)
            for (const item of ret.results) {
                arr.push(await item.data())
            }
        } else {
            arr = fakeResult
        }

        if (!arr.length && isDesktop) {
            panel.classList.add('float-panel-closed')
            return
        }

        if (isDesktop) {
            panel.classList.remove('float-panel-closed')
        }

        renderResults(arr)
    }

    function renderResults(items: any[]) {
        resultsContainer.innerHTML = ''
        for (const item of items) {
            const link = document.createElement('a')
            link.href = item.url
            link.className = 'transition first-of-type:mt-2 lg:first-of-type:mt-0 group block rounded-xl text-lg px-3 py-2 hover:bg-[var(--btn-plain-bg-hover)] active:bg-[var(--btn-plain-bg-active)]'

            const titleDiv = document.createElement('div')
            titleDiv.className = 'transition text-90 inline-flex font-bold group-hover:text-[var(--primary)]'
            titleDiv.textContent = item.meta.title

            const icon = iconTemplate.content.cloneNode(true)
            titleDiv.appendChild(icon)

            const excerptDiv = document.createElement('div')
            excerptDiv.className = 'transition text-sm text-50'
            excerptDiv.innerHTML = item.excerpt

            link.appendChild(titleDiv)
            link.appendChild(excerptDiv)
            resultsContainer.appendChild(link)
        }
    }

    let desktopTimer: ReturnType<typeof setTimeout>
    let mobileTimer: ReturnType<typeof setTimeout>

    desktopInput.addEventListener('input', () => {
        clearTimeout(desktopTimer)
        desktopTimer = setTimeout(() => doSearch(desktopInput.value, true), 200)
    })

    desktopInput.addEventListener('focus', () => {
        if (desktopInput.value) {
            doSearch(desktopInput.value, true)
        }
    })

    mobileInput.addEventListener('input', () => {
        clearTimeout(mobileTimer)
        mobileTimer = setTimeout(() => doSearch(mobileInput.value, false), 200)
    })

    switchBtn.addEventListener('click', () => {
        panel.classList.toggle('float-panel-closed')
    })
}

initSearch()
document.addEventListener('astro:after-swap', initSearch)
</script>
